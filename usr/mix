#export COMPHEP=`cat .compheppath`
script=mix.sh
program=mix.exe

if (test -f .compheppath) then
  export COMPHEP=`cat .compheppath`
else if (test -f ../.compheppath) then
  export COMPHEP=`cat ../.compheppath`
else
  echo "\n  $script (error): .compheppath is not found in ./ or ../. $program can't function\n"
  exit
fi
fi

if (test -z $1) then
   echo "***********************************************"
   echo "* INPUT ERROR: no input parameters            *"
   echo "* execute:                                    *"
   echo "*     ./$script --help                        *"
   echo "***********************************************"
   exit
fi

if (test -x $COMPHEP/bin/mix.exe) then
  if [ x$1 = xDEBUG ]; then
    ddd $COMPHEP/bin/mix.exe
  else
    $COMPHEP/bin/mix.exe $*
  fi
else
  echo "\n  $script (error): no file $COMPHEP/bin/$program. Compile CompHEP in $COMPHEP\n"
  exit
fi

#!/bin/sh
################################################################
# Copyright (C) 2001-2009, CompHEP Collaboration
# on base of script makeCC by A.Pukhov
# authors: A.Sherstnev and A.Kryukov
################################################################
VERSION=4.5.2pre3
CONF_FILE_DIR=chepcode
CONFIG_ERROR=0
F77=gfortran
CC=gcc
STDCFLAGS=
LHAPDF=0
LIBXML=0

SHELP=
SPRINT=
SGCC3=
SDEBUG=
SLHAPDF=
SLIBXML=
SOPTIMISE=
SARCH64=
SROOTHERE=
for i do
  if [ x$i = x--help ]; then
    SHELP=true 
  elif [ x$i = x--with-gcc3 ]; then
    SGCC3=true 
  elif [ x$i = x--debug ]; then
    SDEBUG=true 
  elif [ x$i = x--with-lhapdf ]; then
    SLHAPDF=true 
  elif [ x$i = x--with-libxml ]; then
    SLIBXML=true 
  elif [ x$i = x--optimise ]; then
    SOPTIMISE=true 
  elif [ x$i = x--with-m64 ]; then
    SARCH64=true 
  elif [ x$i = x--version ]; then
    echo $VERSION  > $CONF_FILE_DIR/version
  elif [ x$i = x--with-root ]; then
    SROOTHERE=true 
  elif [ x$i = x--print ]; then
    SPRINT=true 
  else
  echo 'configure (error): Unknown option '$i'! please, read help (./configure --help)'
  CONFIG_ERROR=1
  exit 1
  fi
done

if (test -n "$SHELP" ) then
  echo ''
  echo './configure --debug | --with-gcc3 | --with-lhapdf | --with-libxml | --optimise | --with-root | --with-m64'
  echo '    --debug       - compilation with debugging symbols'
  echo '    --with-gcc3   - shoulf be used if your gcc version is 3.X.X, FORTRAN compiler is g77 '
  echo '    --with-lhapdf - PDF from LHAPDF will be used. lhapdf-config must be in PATH'
  echo '    --with-libxml - mix program will use libxml2 in order to analyze and prepare HepML code'
  echo '    --optimise    - -O3 optimisation will be used'
  echo '    --with-m64    - -m64 option will be used, it is useful at 64-bit machines'
  echo '                    WARNING: THIS OPTION (-m64) DOES NOT WORK AT 32-BIT MACHINES!'
  echo '    --with-root   - a program for trasfering events to a rtuples is prepared (see file ROOTFLAGS)'
  echo '    --print       - print out the ordered compiler/linker configuration'
  echo '    --version     - restore CompHEP version file'
  echo ' N.B.'
  echo ' 1) Compiler/linker options can be changed by editting CC, CFLAGS, CLIBS, F77, F77FLAGS, F77LIBS, RANLIB'
  echo ' 2) Starting from version 4.5.2 gcc-4.X is the default compiler. So, if you need gcc-3.X apply --with-gcc3'
  exit;
fi

cat >test.c <<EOF
int main(void)
{char a; a=1; if (a>-a)return 0;else return 1;}
EOF

echo -n "checking OS and C-compiler ...  "
OS=`uname`
RANLIB=ranlib
if (test $OS = 'Linux') then
  STDCFLAGS="-Wall"
  F77FLAGS=""
  if (test -n "$SGCC3") then
    F77="g77"
  fi
  if (test -n "$SDEBUG") then
    STDCFLAGS="-g ${STDCFLAGS}"
    F77FLAGS="-g ${F77FLAGS}"
  fi
elif (test $OS = 'SunOS') then
  STDCFLAGS=''
  CC=cc
elif (test $OS = 'Darwin') then
  STDCFLAGS='-fsigned-char -Wall'
  F77FLAGS=" -Wall"
  CC=gcc
  RANLIB='ranlib -c'
  if (test -n "$SDEBUG") then
    STDCFLAGS="-g ${STDCFLAGS}"
    F77FLAGS="-g ${F77FLAGS}"
  fi
  if (test -n "$SGCC3") then
    F77="g77"
  fi
else
   CC="gcc";
   STDCFLAGS="-fsigned-char";
   $CC $STDCFLAGS test.c 1>/dev/null 2>/dev/null
   if (test $? -ne 0)then
     echo "configure (err): Unknown UNIX platform, gcc not found. Exit"
     exit 1
   fi
fi

echo "$OS/$CC"
echo "Checking F-compiler ...  $F77"

################################################################
#                   test for ANSI compiler existence           #
################################################################
$CC $STDCFLAGS test.c 1>/dev/null 2>/dev/null
if (test $? -ne 0)then
  CONFIG_ERROR=1
  exit 1
fi

################################################################
echo -n "checking char type...   "
./a.out
if (test $? -ne 0) then
  echo "unsigned."
  CONFIG_ERROR=1
  exit 1
else
  echo "signed."
fi

################################################################
# check of user defined interger type for symbolic calculation #
################################################################
num="OFF"
STDCFLAGS1=
for option in $STDCFLAGS
do
  if (test $option = "-DNUM_DOUBLE" -o $option = "-DNUM_LONG_LONG" \
      -o  $option = "-DNUM_LONG") then
     num=$option
  else
    STDCFLAGS1="$STDCFLAGS1 $option"
  fi
done

echo "void main(void){exit(sizeof(long long  ));}" >test.c
if (test $num = "-DNUM_LONG_LONG") then
  $CC $STDCFLAGS1 test.c 1>/dev/null 2>/dev/null
  if (test $? -ne 0) then
     num="OFF"
  fi
fi

if (test "$num" = "OFF") then

################################################################
#      selection of integer type for symbolic calculation      #
################################################################
  cat <<EOF >test.c
void main(void){exit(sizeof(long ));}
EOF

  echo -n "checking for long type...   "
  $CC $STDCFLAGS1 test.c 1>/dev/null 2>/dev/null
  ./a.out
  rc=$?
  echo "long is $rc bytes."
  if (test $rc -ne 8) then
     num="-DNUM_DOUBLE"
  else
     num="-DNUM_LONG"
  fi
fi

STDCFLAGS="$STDCFLAGS1 $num"

################################################################
#                       search for  X11                        #
################################################################

echo -n "checking for X11 libs ...   "
cat >test.c<<EOF
#include <X11/Xlib.h>
#include <X11/Xutil.h>
#include <X11/keysym.h>
void main(void)
{  static Display *display;
  display = XOpenDisplay (NULL);
}
EOF

x_includes=NO
x_libraries=NO

################################################################
#                               test default                   #
################################################################
$CC $STDCFLAGS -c test.c 1>/dev/null 2>/dev/null
if (test $? -eq 0) then 
  x_includes=  
  $CC $STDCFLAGS test.o -lX11 1>/dev/null 2>/dev/null
  if (test $? -eq 0) then x_libraries=; fi
fi

if (test "$x_includes" = "NO" -o "$x_libraries" = "NO" ) then
################################################################
#                       search by xmkmf                        #
################################################################
mv Makefile Makefile.main

  cat > Imakefile <<'EOF'
findx:
	@echo 'im_incroot="${INCROOT}"; im_usrlibdir="${USRLIBDIR}"; im_libdir="${LIBDIR}"'
EOF

  if (xmkmf) >/dev/null 2>/dev/null && test -f Makefile; then 
    eval `make findx 2>/dev/null | grep -v make`
    if (test  "$x_includes" = "NO") then
      $CC $STDCFLAGS -c test.c -I$im_incroot 1>/dev/null 2>/dev/null 
      if (test $? -eq 0) then  
         x_includes=$im_incroot;
         $CC $STDCFLAGS test.o  -lX11 1>/dev/null 2>/dev/null
         if (test $? -eq 0) then 
           x_libraries= ; 
         else 
           $CC $STDCFLAGS test.o -L$im_usrlibdir -lX11 1>/dev/null 2>/dev/null
           if (test $? -eq 0) then x_libraries=$im_usrlibdir; fi
         fi
      fi
    else 
      $CC $STDCFLAGS test.o -L$im_usrlibdir -lX11 1>/dev/null 2>/dev/null
      if (test $? -eq 0) then  x_libraries=$im_usrlibdir; fi
    fi
  fi
     if (test -f Imakefile) then  rm Imakefile; fi
     if (test -f  Makefile) then  rm  Makefile; fi
mv Makefile.main Makefile
fi


XLIST="X11R6/Z X11R5/Z X11R4/Z Z/X11R6 Z/X11R5 Z/X11R4 local/X11R6/Z
local/X11R5/Z local/X11R4/Z local/Z/X11R6 local/Z/X11R5 local/Z/X11R4
X11/Z Z/X11 local/X11/Z local/Z/X11 X386/Z x386/ Z local/Z  openwin/Z 
openwin/share/Z"

################################################################
#                  search x-includes from XLIST                #
################################################################
if (test "$x_includes" = "NO") then
  for dir in $XLIST
  do
    test_dir=/usr/`echo $dir|sed s/Z/include/`
    if ( test -r "$test_dir/X11/Xlib.h") then
      $CC $STDCFLAGS -c test.c -I$test_dir 1>/dev/null 2>/dev/null
      if (test $? -eq 0) then
        x_includes=$test_dir
        $CC $STDCFLAGS test.o  -lX11 1>/dev/null 2>/dev/null
        if (test $? -eq 0) then
          x_libraries= ;
        else 
          test_dir=/usr/`echo $dir|sed s/Z/lib/`
          $CC $STDCFLAGS test.o -L$test_dir -lX11 1>/dev/null 2>/dev/null 
          if (test $? -eq 0) then 
            x_libraries=$test_dir; 
            break
          fi
        fi
      fi
    fi
  done
fi

################################################################
#                search x-includes from XLIST                  #
################################################################
if (test "$x_includes" != "NO"  -a "$x_libraries" = "NO" ) then
  for dir in $XLIST
  do
    test_dir=/usr/`echo $dir|sed s/Z/lib/`
    $CC $STDCFLAGS test.o -L$test_dir -lX11 1>/dev/null 2>/dev/null 
    if (test $? -eq 0) then 
      x_libraries=$test_dir; 
      break
    fi
  done
fi
rm a.out test.*

if (test "$x_includes" = "NO"  -o "$x_libraries" = "NO" ) then
  echo "configure (err): X11 is not detected."
  echo '  If you use Ubuntu, you may need to install the xlibs-dev package'
  CONFIG_ERROR=1
  exit 1
fi


################################################################
# Set xinclude info
if ( test "$x_includes") then  
  STDCFLAGS="$STDCFLAGS -I$x_includes" 
fi

################################################################
# Set xlib info
if (test "$x_libraries") then
  CLIBS="-L$x_libraries"
fi

echo "OK"

################################################################
#          set proper standard C/FORTRAN libs                  #
################################################################

CLIBS="-Llib $CLIBS -lX11 -lm"
F77LIBS="-lgfortran -lgcc"
if (test -n "$SGCC3") then
  CLIBS="$CLIBS -lg2c"
  F77LIBS=""
fi

################################################################
#                      search for LHAPDF lib                   #
################################################################
if (test -n "$SLHAPDF") then
  LHAPDF=1
  echo -n "checking for LHAPDF...  "
  if command -v lhapdf-config >/dev/null 2>&1; then
    LHAPDF_CFLAGS=`lhapdf-config --cflags`
    LHAPDF_LIBS=`lhapdf-config --libs`
    echo "found (lhapdf-config)"
  else
    echo "  configure (err): lhapdf-config not found. Exit"
    exit 1
  fi
fi

################################################################
#                      search for LIBXML2 lib                  #
################################################################
if (test -n "$SLIBXML") then
  LIBXML=1
  echo "checking for libxml2...  found"
  if [ x$LIBXMLIB = x ]; then
    echo "  configure (warn): variable LIBXMLLIB is not defined. So, /usr/lib is used"
    LIBXMLLIB=/usr/lib
  fi
  if [ x$LIBXMLINC = x ]; then
    echo "  configure (warn): variable LIBXMLINC is not defined. So, /usr/include/libxml2 is used"
    LIBXMLINC=/usr/include/libxml2
  fi
fi

################################################################
#                      search for ROOT headers/libs            #
################################################################
if (test -n "$SROOTHERE") then
  LIBROOT=1
  echo -n "checking for root libraries...  "
  if [ x$ROOTSYS = x ]; then
    echo "configure (err): variable ROOTSYS is not defined. Exit"
    exit 1
  else
    echo "found"
    ROOTINC=`$ROOTSYS/bin/root-config --cflags`
    ROOTLIB=`$ROOTSYS/bin/root-config --libs`
    STDCFLAGS="$STDCFLAGS -DROOTused"
  fi
fi

################################################################
#                      optimisation options                    #
################################################################
echo -n "checking for optimisation options...  "
if (test -n "$SOPTIMISE") then
  STDCFLAGS="-O2 $STDCFLAGS"
  F77FLAGS="-O2 $F77FLAGS"
  echo "-O2"
else 
  echo "no"
fi

################################################################
#                      -m64 option                             #
################################################################
echo -n "checking for architecture options...  "
if (test -n "$SARCH64") then
  STDCFLAGS="$STDCFLAGS -m64" 
  F77FLAGS="-m64 $F77FLAGS"
  echo "-m64"
else 
  STDCFLAGS="$STDCFLAGS -m32" 
  F77FLAGS="-m32 $F77FLAGS"
  echo "-m32"
fi

################################################################
# Output info
STDCFLAGS="$STDCFLAGS -DCOMPHEP"

CFLAGS=""
if (test $LHAPDF = 1) then
  CFLAGS="$CFLAGS -DLHAPDF $LHAPDF_CFLAGS"
  F77FLAGS="$F77FLAGS -DLHAPDF"
  CLIBS="$LHAPDF_LIBS -lstdc++ $CLIBS"
fi

if (test $LIBXML = 1) then
  CFLAGS="$CFLAGS -DLIBXML -I$LIBXMLINC"
  CLIBS="-L$LIBXMLLIB -lxml2 $CLIBS"
fi
CFLAGS="$STDCFLAGS $CFLAGS"

if (test -n "$SPRINT") then
  echo "======================================================="
  echo "Ordered configuration:"
  echo "CC:       $CC"
  echo "CFLAGS:   $CFLAGS"
  echo "CLIBS:    $CLIBS"
  echo "F77:      $F77"
  echo "F77FLAGS: $F77FLAGS"
  echo "F77LIBS:  $F77LIBS"
  echo "RANLIB:   $RANLIB"
  echo "ROOTINC:  $ROOTINC"
  echo "ROOTLIB:  $ROOTLIB"
  echo "======================================================="
  exit 1
fi

echo $CC       > $CONF_FILE_DIR/CC
echo $CFLAGS   > $CONF_FILE_DIR/CFLAGS
echo $CLIBS    > $CONF_FILE_DIR/CLIBS

echo $F77      > $CONF_FILE_DIR/F77
echo $F77FLAGS > $CONF_FILE_DIR/F77FLAGS
echo $F77LIBS  > $CONF_FILE_DIR/F77LIBS

echo $RANLIB   > $CONF_FILE_DIR/RANLIB
echo $ROOTINC  > $CONF_FILE_DIR/ROOTFLAGS
echo $ROOTLIB  > $CONF_FILE_DIR/ROOTLIBS

echo "======================================="
echo "User can change any compilation/linking options editting "
echo "CC CFLAGS CLIBS F77 F77FLAGS F77LIBS RANLIB ROOTFLAGS ROOTLIBS "
echo ""
echo "In order to compile CompHEP execute make"
echo "======================================="
